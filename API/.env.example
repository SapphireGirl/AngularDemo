## Placeholder-only example file. Runtime uses .env.local for local development.
PORT=3000
SQL_SERVER=your-sql-server-hostname
SQL_DATABASE=your_database_name
AUTH_TOKEN_SECRET=your_local_dev_token_secret
AUTH_TOKEN_TTL_SECONDS=3600

# Windows Authentication (recommended on Windows)
SQL_TRUSTED_CONNECTION=true
# Optional: set if your machine uses a different installed ODBC SQL Server driver
# SQL_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# SQL Authentication (set SQL_TRUSTED_CONNECTION=false and fill these in)
# SQL_USER=your_sql_username
# SQL_PASSWORD=your_sql_password

SQL_ENCRYPT=false
SQL_TRUST_SERVER_CERTIFICATE=true
SQL_CATALOG_TABLE=your_catalog_table_name
