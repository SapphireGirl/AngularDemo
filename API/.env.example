PORT=3000
SQL_SERVER=localhost
SQL_DATABASE=AngularDemo

# Windows Authentication (recommended on Windows)
SQL_TRUSTED_CONNECTION=true
# Optional: set if your machine uses a different installed ODBC SQL Server driver
# SQL_ODBC_DRIVER=ODBC Driver 17 for SQL Server

# SQL Authentication (set SQL_TRUSTED_CONNECTION=false and fill these in)
# SQL_USER=sa
# SQL_PASSWORD=yourStrong(!)Password

SQL_ENCRYPT=false
SQL_TRUST_SERVER_CERTIFICATE=true
SQL_CATALOG_TABLE=CatalogItems
